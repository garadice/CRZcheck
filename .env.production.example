# ============================================================
# CRZ Monitor — Production Environment Configuration
# Copy to .env and fill in ALL CHANGE_ME placeholders.
#   cp .env.production.example .env
#   chmod 600 .env
# ============================================================

# --- Database ---
# Generate a strong password:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=CHANGE_ME
# Streamlit runs outside Docker, connects via localhost:5433.
# Replace CHANGE_ME with the same password as above.
DATABASE_URL=postgresql://crz:CHANGE_ME@127.0.0.1:5433/crz_monitor

# --- CRZ Ingestion ---
CRZ_EXPORT_BASE_URL=https://www.crz.gov.sk/export
CRZ_ROLLING_WINDOW_DAYS=90
CRZ_RATE_LIMIT_DAY_SECONDS=2.0
CRZ_RATE_LIMIT_NIGHT_SECONDS=0.4

# --- Storage ---
RAW_DATA_DIR=data/raw

# --- App ---
APP_ENV=production
LOG_LEVEL=INFO
SQL_ECHO=false

# --- Backup ---
BACKUP_DIR=/opt/crz-monitor/backups
RETENTION_DAYS=30
