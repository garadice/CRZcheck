# Database
DATABASE_URL=postgresql://crz:crz_local@localhost:5433/crz_monitor

# CRZ Ingestion
CRZ_EXPORT_BASE_URL=https://www.crz.gov.sk/export
CRZ_ROLLING_WINDOW_DAYS=90
CRZ_RATE_LIMIT_DAY_SECONDS=2.0
CRZ_RATE_LIMIT_NIGHT_SECONDS=0.4

# Storage
RAW_DATA_DIR=data/raw
SAMPLE_DATA_DIR=data/sample

# App
APP_ENV=development
LOG_LEVEL=INFO

# Backup
BACKUP_DIR=./backups
RETENTION_DAYS=30
