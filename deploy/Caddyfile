# CRZ Monitor — Caddy Reverse Proxy Configuration
#
# Prerequisites:
#   1. Install Caddy: https://caddyserver.com/docs/install
#   2. Set up DNS A record: crz.bacimo.net → your server IP
#   3. Generate bcrypt hash for auth: caddy hash-password --plaintext 'your-password'
#   4. Replace <BCRYPT_HASH> below with the generated hash
#   5. Open ports 80 and 443 in firewall: sudo ufw allow 80/tcp && sudo ufw allow 443/tcp

crz.bacimo.net {
    # Basic authentication — replace hash with your generated hash
    basic_auth {
        crz <BCRYPT_HASH>
    }

    # Security headers
    header {
        # Enable HSTS (1 year)
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # Prevent MIME type sniffing
        X-Content-Type-Options "nosniff"
        # Clickjacking protection — allow framing from same origin (Streamlit needs this)
        X-Frame-Options "SAMEORIGIN"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Reverse proxy to Streamlit
    # Caddy automatically handles WebSocket upgrades with reverse_proxy
    reverse_proxy 127.0.0.1:8501
}
